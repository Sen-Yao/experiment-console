# Copy to /mnt/user/appdata/experiment-console/config/production.env on Yggdrasil.
# Do not add tokens or private-key material to this file.
EXPERIMENT_CONSOLE_UID=10001
EXPERIMENT_CONSOLE_GID=10001
EXPERIMENT_CONSOLE_PORT=5174
EXPERIMENT_CONSOLE_IMAGE_TAG=production
EXPERIMENT_CONSOLE_AUTHORITY_ROLE=authoritative
# Stable across restarts and releases. Do not reuse for a development Console.
EXPERIMENT_CONSOLE_INSTANCE_ID=yggdrasil-production
EXPERIMENT_CONSOLE_STATE_PATH=/mnt/user/appdata/experiment-console/state
EXPERIMENT_CONSOLE_RESULTS_PATH=/mnt/user/appdata/experiment-console/results
EXPERIMENT_CONSOLE_WANDB_SECRET_FILE=/mnt/user/appdata/experiment-console/secrets/wandb_api_key
EXPERIMENT_CONSOLE_API_TOKEN_SECRET_FILE=/mnt/user/appdata/experiment-console/secrets/console_api_token
EXPERIMENT_CONSOLE_HCCS_SSH_KEY_FILE=/mnt/user/appdata/experiment-console/secrets/hccs_service_key
EXPERIMENT_CONSOLE_HCCS_SSH_CONFIG_FILE=/mnt/user/appdata/experiment-console/config/hccs_ssh_config
EXPERIMENT_CONSOLE_HCCS_KNOWN_HOSTS_FILE=/mnt/user/appdata/experiment-console/config/hccs_known_hosts
EXPERIMENT_CONSOLE_DEFAULT_ENTITY=HCCS
EXPERIMENT_CONSOLE_DEFAULT_PROJECT=DualRefGAD
EXPERIMENT_CONSOLE_DEFAULT_REMOTE_HOST=HCCS-25
EXPERIMENT_CONSOLE_DEFAULT_REMOTE_CWD=/home/linziyao/DualRefGAD
EXPERIMENT_CONSOLE_DEFAULT_CONDA_ENV=DualRefGAD
# Transient source failures are recorded immediately but become actionable
# incidents only after both the count and duration thresholds are satisfied.
EXPERIMENT_CONSOLE_SYNC_ERROR_CONSECUTIVE=3
EXPERIMENT_CONSOLE_SYNC_ERROR_GRACE_SECONDS=900
EXPERIMENT_CONSOLE_ARTIFACT_SYNC_ERROR_CONSECUTIVE=3
EXPERIMENT_CONSOLE_ARTIFACT_SYNC_ERROR_GRACE_SECONDS=900
EXPERIMENT_CONSOLE_MONITOR_EXTERNAL_ERROR_CONSECUTIVE=3
EXPERIMENT_CONSOLE_MONITOR_EXTERNAL_ERROR_GRACE_SECONDS=900
