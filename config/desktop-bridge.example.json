{
  "ssh_target": "HCCS-25",
  "ssh_config_file": "/Users/you/.ssh/config",
  "known_hosts_file": "/Users/you/.ssh/known_hosts",
  "poll_interval_seconds": 30,
  "capture_lines": 80,
  "max_event_records": 256,
  "status_file": "/Users/you/Library/Application Support/Experiment Wake Bridge/status.json",
  "event_file": "/Users/you/Library/Application Support/Experiment Wake Bridge/events.json",
  "lock_file": "/Users/you/Library/Application Support/Experiment Wake Bridge/bridge.lock",
  "codex_command": [
    "/Applications/ChatGPT.app/Contents/Resources/codex",
    "app-server",
    "--stdio"
  ]
}
