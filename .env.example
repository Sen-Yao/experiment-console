# v3 Yggdrasil deployment values. Keep this file outside Git when populated.
EXPERIMENT_CONSOLE_IMAGE_TAG=3
EXPERIMENT_CONSOLE_INSTANCE_ID=yggdrasil-production-v3
EXPERIMENT_CONSOLE_STATE_PATH=/var/lib/experiment-console-v3
EXPERIMENT_CONSOLE_SERVER_PROFILES_PATH=/etc/experiment-console/server-profiles.json
EXPERIMENT_CONSOLE_API_TOKEN_SECRET_FILE=/etc/experiment-console/secrets/console_api_token
EXPERIMENT_CONSOLE_SSH_KEY_FILE=/etc/experiment-console/secrets/hccs_ssh_key
EXPERIMENT_CONSOLE_SSH_CONFIG_FILE=/etc/experiment-console/ssh_config
EXPERIMENT_CONSOLE_KNOWN_HOSTS_FILE=/etc/experiment-console/known_hosts
